# Configuración de API para Trader LSTM
# Copiar este archivo a .env y rellenar con tus credenciales

# URL base de la API de Alpaca
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Token de API para operaciones
ALPACA_API_TOKEN=tu_api_token_aqui

# Token de administrador
ALPACA_ADMIN_TOKEN=tu_admin_token_aqui

# ID del actor
ALPACA_ACTOR_ID=tu_actor_id_aqui

# Configuración de logging
LOG_LEVEL=INFO
LOG_FILE=logs/trader_app.log

# Configuración del bot
LOOP_INTERVAL_MS=4000
LOOP_RETRY_MS=1200
MAX_LOOP_ERRORS=3
MAX_DRAWDOWN_STOP_PCT=8.0

# Modelos y datos
TICKERS=AAPL,MSFT
SAMPLE_PERIODS=252
PREDICTION_HORIZON=5